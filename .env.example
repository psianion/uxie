DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_DEV_GUILD_ID=
DISCORD_OWNER_ID=
SCRYPT_SERVER_URL=http://scrypt:3000
SCRYPT_MCP_URL=http://scrypt:3000/mcp
SCRYPT_AUTH=

# Deployment label shown in /ping's 🌐 Host row (e.g. local, vps, prod). Defaults to "local".
UXIE_ENV=local

# --- Privileged: Scrypt restart from the /ping panel (OFF by default) ---
# When enabled, a degraded/down /ping shows an owner-only 🔧 Restart Scrypt button that
# runs SCRYPT_RESTART_CMD. SECURITY: fixed-argv (no shell), leading binary allowlisted to
# `docker`, owner + dev-guild gated, confirm step, single-flight, 60s cooldown, 30s timeout,
# and a minimal child env (PATH/DOCKER_HOST only — never the bot/scrypt secrets). Requires
# the bot host to have Docker access (or the socket mounted if uxie itself runs in Docker).
ALLOW_SCRYPT_RESTART=0
SCRYPT_RESTART_CMD=docker compose restart scrypt
