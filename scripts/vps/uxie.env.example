# /opt/secrets/uxie.env — Uxie production secrets.
#
# Permissions: chmod 600, owned by ubuntu:ubuntu
# Loaded by docker compose via env_file: on the VPS.
# DO NOT COMMIT real values to git. This file is a TEMPLATE.

# ------------------------------------------------------------------------------
# Discord application credentials (required).
# ------------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_DEV_GUILD_ID=
DISCORD_OWNER_ID=

# ------------------------------------------------------------------------------
# Scrypt integration.
# ------------------------------------------------------------------------------
# Loopback-only: uxie's env validation rejects plaintext http:// to any
# non-loopback host (SCRYPT_AUTH would otherwise leak on the wire). Since
# uxie runs with network_mode: host, scrypt's 127.0.0.1:3777 binding is
# directly reachable.
SCRYPT_SERVER_URL=http://127.0.0.1:3777

# Must match SCRYPT_AUTH_TOKEN in /opt/secrets/scrypt.env.
SCRYPT_AUTH=

# ------------------------------------------------------------------------------
# Runtime.
# ------------------------------------------------------------------------------
UXIE_ENV=vps

# Keep 0 in prod. Enabling this inside a container would require mounting
# docker.sock — root-equivalent access to the host. Scrypt already self-heals
# via its own restart policy + healthcheck, so uxie doesn't need to restart it.
ALLOW_SCRYPT_RESTART=0

# ------------------------------------------------------------------------------
# para-raid v2 module (optional — uncomment the whole block to enable /raid).
# All-or-none: uxie fails boot loudly on a partial group (lib/env.ts superRefine).
# Also flips on the GuildMessages + MessageContent Discord intents (bot/client.ts) —
# MessageContent is privileged, so enable it in the dev portal (Bot > Privileged
# Gateway Intents) first, or login fails with "disallowed intents". The bot also
# needs the CreatePublicThreads, SendMessagesInThreads, and AddReactions guild
# permissions for /raid open + the message relay to work.
# ------------------------------------------------------------------------------
# Container-side path to the socket para-raid's daemon listens on — see the
# volume mount in docker-compose.vps.yml (host dir -> same path in-container).
# NOTE: changing para-raid's [daemon].socket_path on the host requires
# `systemctl --user restart para-raid` (the unit does not hardcode the socket).
# PARARAID_SOCKET=/home/ubuntu/.para-raid-run/para-raid.sock

# Must match the token under [adapters.uxie] in para-raid's config.toml.
# PARARAID_ADAPTER_TOKEN=

# Must match [signing].secret in para-raid's config.toml.
# PARARAID_SIGNING_SECRET=

# Loopback-only webhook receiver port (docker-compose.vps.yml runs uxie with
# network_mode: host, so 127.0.0.1:<this port> is directly reachable from the
# para-raid daemon on the same host). NOTE: para-raid's install/update scripts
# only rewrite [auth]/[signing] in config.toml — [adapters.uxie].webhook_url
# must be hand-edited to http://127.0.0.1:18901/api/webhooks/para-raid.
# PARARAID_WEBHOOK_PORT=18901
